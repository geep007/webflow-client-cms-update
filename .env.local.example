# Webflow API token — must have cms:read and cms:write scopes
# Get this from: Webflow Dashboard → Site Settings → Apps & Integrations → API Access
WEBFLOW_API_TOKEN=your_api_token_here

# Your Webflow Site ID
# Get this from: Webflow Dashboard → Site Settings → General → Site ID
# Or from the URL: webflow.com/dashboard/sites/<SITE_ID>
WEBFLOW_SITE_ID=your_site_id_here
